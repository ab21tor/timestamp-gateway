# ── LND REST endpoint ────────────────────────────────────────────────────────
# Hostname, IP, or .onion address of your LND node's REST API.
LND_HOST=

# REST API port (LND default is 8080).
LND_PORT=8080

# Hex-encoded invoice macaroon. On most nodes:
#   xxd -p -c 256 ~/.lnd/data/chain/bitcoin/mainnet/invoice.macaroon
LND_MACAROON_HEX=

# Hex-encoded readonly macaroon (optional). Used by /health to call LND /v1/getinfo.
# The readonly macaroon has the minimum permissions needed for the health check.
# If not set, /health falls back to LND_MACAROON_HEX.
#   lncli bakemacaroon info:read --save_to readonly.macaroon
#   xxd -p -c 256 readonly.macaroon
LND_READONLY_MACAROON_HEX=

# ── Tor SOCKS proxy ──────────────────────────────────────────────────────────
# Used to route LND connections through Tor (required if LND_HOST is .onion).
# Set to tor:9050 when using the bundled Tor container from docker-compose.yml.
# Leave blank for direct clearnet LND connections.
TOR_PROXY=tor:9050

# ── Gateway pricing ──────────────────────────────────────────────────────────
# Satoshis charged per timestamp request. Must be a positive integer.
GATEWAY_PRICE_SATS=500

# ── LND TLS ──────────────────────────────────────────────────────────────────
# Set to true only if your LND REST API certificate is signed by a trusted CA.
# Most home nodes and self-hosted nodes use self-signed certs; leave false.
LND_TLS_VERIFY=false

# ── OTS backend ──────────────────────────────────────────────────────────────
# calendar  — submit paid digests to your operator-controlled OTS calendar (real mode).
# public    — submit to the OpenTimestamps public aggregators (compatibility/testing only).
#
# calendar is the correct value for production. public is for testing without otsd.
# These two modes are mutually exclusive:
#   - OTS_CALENDAR_URL is required when OTS_BACKEND_MODE=calendar.
#   - OTS_CALENDAR_URL must NOT be set when OTS_BACKEND_MODE=public.
OTS_BACKEND_MODE=calendar

# URL of the operator-controlled OpenTimestamps calendar server (otsd).
# Required when OTS_BACKEND_MODE=calendar.
# When using the bundled otsd container from docker-compose.yml: http://otsd:14788
# For an external otsd: http://<host>:<port>
# Leave blank or omit when OTS_BACKEND_MODE=public.
OTS_CALENDAR_URL=http://otsd:14788
