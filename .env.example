# LND REST endpoint
# Hostname, IP, or .onion address of your LND node's REST API.
LND_HOST=
# REST API port (LND default is 8080).
LND_PORT=8080
# Hex-encoded INVOICE macaroon: invoice scope only.
# NEVER use admin.macaroon. The gateway only creates and reads invoices.
# Example:
#   lncli bakemacaroon invoices:read invoices:write address:read offchain:read --save_to invoice.macaroon
#   xxd -p -c 256 invoice.macaroon
LND_MACAROON_HEX=
# Hex-encoded readonly macaroon, optional but recommended.
# Used only by /health to call LND /v1/getinfo with least privilege.
# Falls back to LND_MACAROON_HEX if unset.
LND_READONLY_MACAROON_HEX=
# Tor SOCKS proxy.
# Required if LND_HOST is .onion. Leave blank for direct clearnet LND.
# Use tor:9050 with the bundled Docker Compose Tor service.
TOR_PROXY=tor:9050
# Gateway URL for operator scripts (status, audit, paid proof test).
# Defaults to the Tailscale IP of this VPS. Override for other deployments.
GATEWAY_URL=http://100.98.161.106:8000

# Price charged per timestamp request, in sats. Must be a positive integer.
GATEWAY_PRICE_SATS=500
# LND REST TLS certificate verification.
# Usually false for self-hosted LND with a self-signed certificate.
# Use proper HTTPS/TLS in production because L402 credentials travel in headers.
LND_TLS_VERIFY=false
# OTS backend mode.
# calendar = operator-controlled OTS calendar, intended production mode.
# public = public OpenTimestamps aggregators, compatibility/testing only.
OTS_BACKEND_MODE=calendar
# Operator-controlled OpenTimestamps calendar server.
# Required when OTS_BACKEND_MODE=calendar.
# Docker Compose default: http://otsd:14788
# Bare-metal/external otsd example: http://127.0.0.1:14788
# Leave blank when OTS_BACKEND_MODE=public.
OTS_CALENDAR_URL=http://otsd:14788
# L402 macaroon root signing key. REQUIRED for production.
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Keep it secret. Never commit it.
L402_SECRET_HEX=
# DEV ONLY, unsafe for production.
# If true and L402_SECRET_HEX is unset, a random per-process key is generated.
# That invalidates paid-but-unredeemed tokens on every restart.
L402_ALLOW_EPHEMERAL_SECRET=false
# Validity window, in seconds, for an issued L402 token.
# A client may retry the paid request with the same token and preimage within this window.
L402_TOKEN_EXPIRY_SECONDS=3600
# Calendar-mode OTS submission retry count. Must be >= 1.
OTS_SUBMIT_MAX_ATTEMPTS=5
# Delay between OTS submission attempts, in seconds. Must be >= 0.
OTS_SUBMIT_BACKOFF_SECONDS=2
# Durable obligation log (SQLite).
# Records each settled payment as an obligation to stamp, so a paid request is
# never lost if calendar submission fails: the row stays 'needs_stamp' and the
# background sweeper retries it until stamped. This is a durable backstop to the
# in-memory proof cache, NOT a replacement — the DB is never used to validate a
# proof. Under Docker this path lives on the persistent gateway_data volume; the
# process fails to start if the path is unwritable.
OBLIGATIONS_DB_PATH=/var/lib/timestamp-gateway/obligations.db
# How often the sweeper retries obligations left in 'needs_stamp', in seconds.
# Must be a positive integer.
OBLIGATION_SWEEP_INTERVAL=1800
